// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

enum ApplicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique

  users User[]
}

model User {
  id           Int     @id @default(autoincrement())
  fullName     String
  email        String  @unique
  passwordHash String
  isActive     Boolean @default(true)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  // Two distinct relations to Application for the audit trail
  createdApplications Application[] @relation("CreatedApps")
  updatedApplications Application[] @relation("UpdatedApps")

  createdAt DateTime @default(now())
}

model Application {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  description         String
  version             String
  publishedOn         DateTime
  developerName       String
  appUrl              String
  coreFunctionalities String

  // Stored as native Postgres arrays for filterable tags
  frontendStack String[]
  backendStack  String[]

  // Manual file metadata (nullable — a manual is optional at create time)
  manualStorageName  String?
  manualOriginalName String?
  manualMimeType     String?
  manualSize         Int?

  // Card presentation
  iconIndex Int
  theme     String
  sortOrder Int    @default(0)

  status ApplicationStatus @default(PUBLISHED)

  // Audit trail
  createdById Int
  createdBy   User  @relation("CreatedApps", fields: [createdById], references: [id])
  updatedById Int?
  updatedBy   User? @relation("UpdatedApps", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}